# Local Database configuration (SQLite for local zero-config, change provider in prisma/schema.prisma for PostgreSQL)
DATABASE_URL="file:./dev.db"

# JWT Authentication secret key (Must be at least 32 characters long in production)
JWT_SECRET="almi-group-super-secret-key-2026-must-be-long-enough"

# Resend Email Integration (Optional, defaults to console log mock sending if omitted)
RESEND_API_KEY="mock-key"
EMAIL_FROM="notifications@almi.bg"
ADMIN_NOTIFICATION_EMAIL="admin@almi.bg"

# Site settings
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
