# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Local development (SQLite — zero config, run: npm run db:setup to initialize)
DATABASE_URL="file:./prisma/dev.db"

# Production (PostgreSQL on Vercel Postgres, Neon, Supabase, PlanetScale, etc.)
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
# ⚠️  Remember to change provider to "postgresql" in prisma/schema.prisma for production

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# REQUIRED: Must be at least 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET="almi-group-super-secret-key-2026-must-be-long-enough"

# =============================================================================
# EMAIL (OPTIONAL)
# =============================================================================
# Resend API key — if omitted, email sending is mocked to console
RESEND_API_KEY="mock-key"
EMAIL_FROM="notifications@almi.bg"
ADMIN_NOTIFICATION_EMAIL="admin@almi.bg"

# =============================================================================
# SITE URL
# =============================================================================
# Set to your production domain on Vercel
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
